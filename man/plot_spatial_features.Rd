  pu$id <- seq_len(nrow(pu))
  pu$cost <- seq_len(nrow(pu))

  features <- data.frame(
    id = 1:2,
    name = c("feature_1", "feature_2")
  )

  dist_features <- data.frame(
    pu = rep(pu$id, each = 2),
    feature = rep(features$id, times = nrow(pu)),
    amount = c(
      4, 1,
      3, 2,
      2, 3,
      1, 4
