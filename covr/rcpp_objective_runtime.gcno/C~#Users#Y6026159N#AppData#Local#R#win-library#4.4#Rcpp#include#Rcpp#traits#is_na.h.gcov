        -:   26:namespace Rcpp{
        -:   27:
        -:   28:    namespace traits{
        -:   29:
        -:   30:        // default to always false, applies to VECSXP, EXPRSXP and RAWSXP
        -:   31:        template <int RTYPE>
        -:   32:        bool is_na(typename storage_type<RTYPE>::type) {
        -:   33:            return false;
        -:   34:        }
        -:   35:
        -:   36:        template <>
