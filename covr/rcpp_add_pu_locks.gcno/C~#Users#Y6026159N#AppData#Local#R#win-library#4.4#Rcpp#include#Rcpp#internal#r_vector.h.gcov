        -:   71:/**
        -:   72: * Initializes a vector of the given SEXP type. The template fills the
        -:   73: * vector with the value 0 of the appropriate type, for example
        -:   74: * an INTSXP vector is initialized with (int)0, etc...
        -:   75: */
        -:   76:template<int RTYPE> void r_init_vector(SEXP x) {		// #nocov start
        -:   77:    typedef typename ::Rcpp::traits::storage_type<RTYPE>::type CTYPE;
