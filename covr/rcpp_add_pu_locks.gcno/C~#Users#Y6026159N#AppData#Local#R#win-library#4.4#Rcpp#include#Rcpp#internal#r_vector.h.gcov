        -:   50:/**
        -:   51: * The value 0 statically casted to the appropriate type for
        -:   52: * the given SEXP type
        -:   53: */
        -:   54:template <int RTYPE,typename CTYPE>				// #nocov start
        -:   55:inline CTYPE get_zero() {
        -:   56:    return static_cast<CTYPE>(0);
