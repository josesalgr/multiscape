    #####:   33:template <typename T> T clone(const T& object) {
    #####:   34:    Shield<SEXP> x(const_cast<T&>(object));
    #####:   35:    Shield<SEXP> copy(Rf_duplicate(x));
    #####:   36:    return T((SEXP)copy);
    #####:   37:}
