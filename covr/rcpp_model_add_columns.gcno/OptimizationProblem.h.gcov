        -:  230:  // ---------------------------
        -:  231:  // Add one constraint row (0-based variable indices)
        -:  232:  // ---------------------------
        -:  233:  inline void addRow(const std::vector<int>& cols,
        -:  234:                     const std::vector<double>& vals,
        -:  235:                     std::string sense,
        -:  236:                     double rhs,
        -:  237:                     const std::string& name = "") {
        -:  238:
        -:  239:    if (cols.size() != vals.size())
        -:  240:      Rcpp::stop("addRow: cols and vals length mismatch.");
        -:  241:
        -:  242:    if (!(sense == "<=" || sense == ">=" || sense == "==" || sense == "="))
        -:  243:      Rcpp::stop("addRow: invalid sense.");
        -:  244:
        -:  245:    if (sense == "=") sense = "==";
        -:  246:
        -:  247:    if (!std::isfinite(rhs))
        -:  248:      Rcpp::stop("addRow: rhs must be finite.");
        -:  249:
        -:  250:    const std::size_t row = _rhs.size(); // 0-based row index
        -:  251:
        -:  252:    _rhs.push_back(rhs);
        -:  253:    _sense.push_back(sense);
        -:  254:    _name.push_back(name); // aligned 1:1 with rhs/sense
        -:  255:
        -:  256:    const std::size_t nvar = _obj.size();
        -:  257:    for (std::size_t t = 0; t < cols.size(); ++t) {
        -:  258:      const int col = cols[t];
        -:  259:      if (col < 0 || (std::size_t)col >= nvar)
        -:  260:        Rcpp::stop("addRow: col out of range.");
        -:  261:
        -:  262:      const double v = vals[t];
        -:  263:      if (!std::isfinite(v))
        -:  264:        Rcpp::stop("addRow: non-finite coefficient.");
        -:  265:
        -:  266:      if (v == 0.0) continue;
        -:  267:
        -:  268:      _A_i.push_back(row);
        -:  269:      _A_j.push_back((std::size_t)col);
        -:  270:      _A_x.push_back(v);
        -:  271:    }
        -:  272:  }
