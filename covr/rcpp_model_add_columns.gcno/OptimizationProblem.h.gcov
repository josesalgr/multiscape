        -:  174:  inline std::size_t beginConstraintBlock(const std::string& name,
        -:  175:                                          const std::string& tag = "") {
        -:  176:    ActiveBlock b;
        -:  177:    b.id    = _next_block_id++;     // reserve ID now
        -:  178:    b.kind  = "constraint";
        -:  179:    b.name  = name;
        -:  180:    b.tag   = tag;
        -:  181:    b.start = nrow_used();
        -:  182:    _active_constraint_blocks.push_back(b);
        -:  183:    return b.id;
        -:  184:  }
        -:  185:
        -:  186:  inline void setActiveConstraintBlockTag(std::size_t id, const std::string& tag) {
        -:  187:    for (std::size_t i = _active_constraint_blocks.size(); i-- > 0; ) {
        -:  188:      if (_active_constraint_blocks[i].id == id) {
        -:  189:        _active_constraint_blocks[i].tag = tag;
        -:  190:        return;
        -:  191:      }
        -:  192:    }
        -:  193:    Rcpp::stop("setActiveConstraintBlockTag: active block id not found.");
        -:  194:  }
        -:  195:
        -:  196:  // drop_if_empty=true => if no rows were added in this block, it won't be registered
        -:  197:  inline std::size_t endConstraintBlock(std::size_t id,
        -:  198:                                        bool drop_if_empty = true,
        -:  199:                                        const std::string& tag_override = "") {
        -:  200:
        -:  201:    if (_active_constraint_blocks.empty())
        -:  202:      Rcpp::stop("endConstraintBlock: no active constraint blocks.");
        -:  203:
        -:  204:    ActiveBlock b = _active_constraint_blocks.back();
        -:  205:    if (b.id != id)
        -:  206:      Rcpp::stop("endConstraintBlock: id mismatch (must close in LIFO order).");
        -:  207:
        -:  208:    _active_constraint_blocks.pop_back();
        -:  209:
        -:  210:    const std::size_t row_start = b.start;
        -:  211:    const std::size_t row_end   = nrow_used();
        -:  212:
        -:  213:    if (drop_if_empty && row_end <= row_start) return 0;
        -:  214:
        -:  215:    const std::string tag_final = (tag_override.empty() ? b.tag : tag_override);
        -:  216:
        -:  217:    // IMPORTANT: preserve reserved id
        -:  218:    BlockRange closed;
        -:  219:    closed.id    = b.id;
        -:  220:    closed.kind  = "constraint";
        -:  221:    closed.name  = b.name;
        -:  222:    closed.start = row_start;
        -:  223:    closed.end   = row_end;
        -:  224:    closed.tag   = tag_final;
        -:  225:
        -:  226:    _registry.push_back(closed);
        -:  227:    return closed.id;
        -:  228:  }
